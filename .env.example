# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: Required for email notifications to office@peoplelabx.com.
# Configure this via the Secrets panel in the AI Studio UI.
RESEND_API_KEY=

# NOTION_TOKEN: Required server-side secret to authenticate with Notion API.
# Configure this in the Secrets panel in the AI Studio UI.
NOTION_TOKEN=

# NOTION_OPPORTUNITIES_DATA_SOURCE_ID: Required database ID for "05.17.04 Opportunities".
# Configure this in the Secrets panel in the AI Studio UI.
NOTION_OPPORTUNITIES_DATA_SOURCE_ID=

# GOOGLE_CHAT_WEBHOOK_URL: Optional server-side incoming webhook URL for Google Chat notifications.
# Configure this in the Secrets panel in the AI Studio UI if chat alerts are desired.
GOOGLE_CHAT_WEBHOOK_URL=

